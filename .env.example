# FWA Detection MLOps Pipeline
#
# How to use this:
# cp .env.example .env
# Then fill in your actual values in .env
#
# Your .env file is already in .gitignore
# so you won't accidentally push credentials.
# If you ever do — rotate your keys immediately.

# -----------------------------------------------
# AWS
# -----------------------------------------------
# Create a dedicated IAM user for this project.
# Don't use your root account — seriously.
# Permissions needed: S3 full access, SageMaker full access
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# -----------------------------------------------
# S3 Storage
# -----------------------------------------------
# One bucket, three prefixes for Bronze/Silver/Gold.
# Create the bucket manually in AWS console first.
# Bucket name must be globally unique — add your initials if taken.
S3_BUCKET_NAME=fwa-detection-mlops
S3_BRONZE_PATH=s3://fwa-detection-mlops/bronze/
S3_SILVER_PATH=s3://fwa-detection-mlops/silver/
S3_GOLD_PATH=s3://fwa-detection-mlops/gold/

# -----------------------------------------------
# MLflow
# -----------------------------------------------
# Locally just run: mlflow ui
# and point this to localhost.
# In production swap localhost for your EC2 IP.
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_ARTIFACT_ROOT=s3://fwa-detection-mlops/mlflow/

# -----------------------------------------------
# SageMaker
# -----------------------------------------------
# Your 12 digit AWS account ID.
# Find it top right in AWS console.
# The role needs SageMaker + S3 permissions.
AWS_ACCOUNT_ID=
SAGEMAKER_ROLE_ARN=arn:aws:iam::your_account_id:role/SageMakerRole
SAGEMAKER_INSTANCE_TYPE=ml.m5.xlarge

# -----------------------------------------------
# FastAPI
# -----------------------------------------------
# Default port is 8000 — change if something
# else is already running on that port.
# Keep DEBUG=False unless you're troubleshooting.
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=False

# -----------------------------------------------
# Airflow
# -----------------------------------------------
# SQLite is fine for local development.
# Switch to PostgreSQL when you move to production.
# LocalExecutor works for single machine setup.
AIRFLOW__CORE__SQL_ALCHEMY_CONN=sqlite:////home/dhanush/airflow/airflow.db
AIRFLOW__CORE__EXECUTOR=LocalExecutor

# -----------------------------------------------
# Local Data Paths
# -----------------------------------------------
# During development everything runs locally.
# Switch these to S3 paths when deploying.
LOCAL_BRONZE_PATH=data/bronze/
LOCAL_SILVER_PATH=data/silver/
LOCAL_GOLD_PATH=data/gold/

# -----------------------------------------------
# CMS Dataset
# -----------------------------------------------
# Download from data.cms.gov
# Search: Medicare Physician Other Practitioners
# Pick the 2022 file — about 2GB unzipped.
CMS_DATA_FILENAME=Medicare_Physician_Other_Practitioners_2022.csv
CMS_DATA_YEAR=2022

# -----------------------------------------------
# Model Settings
# -----------------------------------------------
# Keep RANDOM_SEED fixed so results are reproducible.
# Changing it mid-project makes experiment comparison meaningless.
MODEL_NAME=fwa_xgboost_classifier
MODEL_VERSION=1.0.0
RANDOM_SEED=42
TEST_SIZE=0.2

# -----------------------------------------------
# FWA Labeling Thresholds
# -----------------------------------------------
# These came from reviewing CMS fraud guidelines.
# Billing 3x above standard rate is a known fraud signal.
# 150 procedures per day is physically impossible for one provider.
# Denial rate above 40% suggests systematic abuse.
# Adjust these after talking to a healthcare domain expert.
FRAUD_BILLING_RATIO_THRESHOLD=3.0
WASTE_PROCEDURES_PER_DAY_THRESHOLD=150
ABUSE_DENIAL_RATE_THRESHOLD=0.4

# -----------------------------------------------
# Drift Monitoring
# -----------------------------------------------
# PSI above 0.2 means significant distribution shift.
# That's the industry standard cutoff — not arbitrary.
# When this fires it triggers automatic retraining via Airflow.
PSI_THRESHOLD=0.2
KL_DIVERGENCE_THRESHOLD=0.1
MONITORING_SCHEDULE=@daily

# -----------------------------------------------
# HIPAA Compliance
# -----------------------------------------------
# Audit logging records every prediction with timestamp,
# model version, input hash, and output.
# Never log raw provider data — only hashed identifiers.
# Keep this enabled — it's what makes this HIPAA-aware.
AUDIT_LOG_PATH=logs/audit/
ENABLE_AUDIT_LOGGING=True
LOG_LEVEL=INFO

# -----------------------------------------------
# Alerts
# -----------------------------------------------
# Slack webhook fires when PSI threshold is breached.
# Create a webhook in your Slack workspace settings.
# If you don't have Slack just leave this empty
# and check the Evidently report manually.
SLACK_WEBHOOK_URL=
ALERT_EMAIL=dpcontract2x.mkt@gmail.com